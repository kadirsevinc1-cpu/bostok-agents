# Bostok Agent Köyü — API Key'ler
# Bu dosyayı .env olarak kopyala, doldur.
# .env dosyasını asla Git'e commit etme!

# ── ÜCRETSİZ PROVIDER'LAR (öncelik sırasına göre) ──────────────
# 1. Groq — console.groq.com (ücretsiz, çok hızlı)
GROQ_API_KEY=

# 2. Cerebras — cloud.cerebras.ai (ücretsiz)
CEREBRAS_API_KEY=

# 3. DeepSeek — platform.deepseek.com (ücretsiz tier)
DEEPSEEK_API_KEY=

# 4. Gemini — aistudio.google.com (ücretsiz tier)
GEMINI_API_KEY=

# 5. Mistral — console.mistral.ai (ücretsiz tier)
MISTRAL_API_KEY=

# ── ÜCRETLİ (son çare) ─────────────────────────────────────────
# 6. Claude — console.anthropic.com (ücretli, en güçlü)
ANTHROPIC_API_KEY=

# ── DİĞER ──────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
